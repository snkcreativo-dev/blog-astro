---
import { siteConfig } from '../config/site';
import { withBase } from '../utils/links';
---

<!--
	BLOQUE: Pie global del sitio
	- Cierra la lectura con branding secundario y accesos rapidos.
	- En un proyecto editorial conviene tratar el footer como parte de la identidad, no como relleno.
-->
<footer class="site-footer">
	<div class="container site-footer__inner">
		<div>
			<p class="footer-label">Cierre de edicion</p>
			<div class="footer-brandline">
				<span class="brand__crest brand__crest--footer" aria-hidden="true">NT</span>
			</div>
			<h2>{siteConfig.title}</h2>
			<p class="site-footer__copy">
				Una publicacion pensada para documentar decisiones tecnicas con una voz editorial,
				contenido versionado en Git y una estructura que se deja leer.
			</p>
		</div>

		<ul class="footer-links">
			{
				siteConfig.footerLinks.map((item) => (
					<li>
						<a href={item.href.startsWith('http') ? item.href : withBase(item.href)}>{item.label}</a>
					</li>
				))
			}
		</ul>
	</div>
</footer>
