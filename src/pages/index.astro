---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { siteConfig } from '../config/site';
import { getPublishedPosts, getUniqueTags } from '../utils/blog';
import { formatDate } from '../utils/format';
import { withBase } from '../utils/links';

const posts = await getPublishedPosts();
const featuredPost = posts.find((post) => post.data.featured) ?? posts[0];
const recentPosts = posts.filter((post) => post.id !== featuredPost?.id).slice(0, 3);
const highlightedTags = getUniqueTags(posts).slice(0, 6);
const leadStory = recentPosts[0];
const columnStories = recentPosts.slice(1);
---

<BaseLayout title={siteConfig.title} description={siteConfig.description}>
	<section class="hero">
		<div class="hero__panel hero__panel--lead">
			<span class="eyebrow">Tema editorial</span>
			<p class="hero__issue">Edicion 01 · Producto, frontend y cultura de construccion</p>
			<h1>Un blog que parece una revista digital y sigue siendo facil de mantener.</h1>
			<p class="lede">
				Portada con jerarquia, ritmo tipografico, criterio visual y una estructura de Astro
				que no sacrifica claridad tecnica por estetica.
			</p>

			<div class="actions">
				<a class="button" href={withBase('/blog/')}>Abrir la edicion</a>
				<a class="button--secondary" href={withBase('/sobre-este-blog/')}>Leer la linea editorial</a>
			</div>
		</div>

		<div class="hero__aside editorial-stack">
			<aside class="panel issue-panel">
				<p class="panel-label">En esta entrega</p>
				<h2>Un sistema visual de publicacion, no una landing generica.</h2>
				<ul class="metric-list">
					<li>Portada con voz propia</li>
					<li>Reticula mas periodistica</li>
					<li>Archivo legible</li>
					<li>CMS listo para edicion</li>
				</ul>
			</aside>

			<aside class="panel note-panel">
				<p class="panel-label">Temas de mesa</p>
				<ul class="topic-list">
					{highlightedTags.map((tag) => <li>{tag}</li>)}
				</ul>
			</aside>
		</div>
	</section>

	{
		featuredPost && (
			<section class="section section--feature">
				<div class="section-heading">
					<div>
						<p class="section-label">Pieza de apertura</p>
						<h2>Articulo destacado</h2>
						<p>
							La portada gana peso cuando hay una historia principal y un contexto visual que la
							acompaña.
						</p>
					</div>
				</div>

				<a class="feature-card" href={withBase(`/blog/${featuredPost.id}/`)}>
					<div>
						<span class="eyebrow">Destacado</span>
						<h2>{featuredPost.data.title}</h2>
						<p>{featuredPost.data.description}</p>
						<div class="post-meta post-meta--feature">
							<span>{formatDate(featuredPost.data.publishDate)}</span>
							<span>{featuredPost.data.author}</span>
							<span>{featuredPost.data.tags.join(' / ')}</span>
						</div>
					</div>

					<div>
						{featuredPost.data.cover ? (
							<img
								class="feature-card__cover"
								src={withBase(featuredPost.data.cover)}
								alt={featuredPost.data.coverAlt ?? `Portada de ${featuredPost.data.title}`}
							/>
						) : (
							<div class="feature-card__cover" />
						)}
					</div>
				</a>
			</section>
		)
	}

	<section class="section section--editorial-grid">
		<div class="section-heading">
			<div>
				<p class="section-label">Mesa de redaccion</p>
				<h2>Ultimos articulos</h2>
				<p>
					El mismo contenido tipado alimenta la portada, el archivo y el CMS. Ese contrato
					claro permite trabajar la forma sin perder la estructura.
				</p>
			</div>
			<a class="button--secondary" href={withBase('/blog/')}>Ver archivo completo</a>
		</div>

		<div class="editorial-grid">
			{leadStory && (
				<div class="editorial-grid__lead">
					<PostCard post={leadStory} />
				</div>
			)}

			<div class="editorial-grid__column">
				{columnStories.map((post) => <PostCard post={post} />)}
			</div>

			<aside class="panel editorial-brief">
				<p class="panel-label">Notas de portada</p>
				<h2>Branding, criterio y lectura.</h2>
				<p>
					El tono editorial no sale solo de una fuente serif. Necesita ritmo, contraste,
					aire, bloques secundarios y una navegacion que parezca propia de una revista.
				</p>
				<a class="button--secondary" href={withBase('/admin/')}>Entrar al escritorio editorial</a>
			</aside>
		</div>
	</section>
</BaseLayout>
