---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getPublishedPosts, getUniqueTags } from '../../utils/blog';

const posts = await getPublishedPosts();
const tags = getUniqueTags(posts);
---

<BaseLayout
	title="Blog"
	description="Archivo completo de articulos sobre Astro, contenido y flujos editoriales modernos."
>
	<section class="page-hero">
		<span class="eyebrow">Archivo editorial</span>
		<h1>Todos los articulos del blog</h1>
		<p>
			Esta pagina centraliza las entradas publicadas y hace visible una idea importante:
			el frontend consulta una coleccion tipada, no una carpeta leida a ciegas.
		</p>
	</section>

	<section class="section">
		<div class="section-heading">
			<div>
				<h2>Etiquetas activas</h2>
				<p>Sirven como taxonomia simple y legible sin introducir complejidad innecesaria.</p>
			</div>
		</div>

		<ul class="topic-list">
			{tags.map((tag) => <li>{tag}</li>)}
		</ul>
	</section>

	<section class="section">
		<div class="post-grid">
			{posts.map((post) => <PostCard post={post} />)}
		</div>
	</section>
</BaseLayout>
