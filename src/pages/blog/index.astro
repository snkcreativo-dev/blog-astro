---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getPublishedPosts, getUniqueTags } from '../../utils/blog';

const posts = await getPublishedPosts();
const tags = getUniqueTags(posts);
---

<BaseLayout
	title="Blog"
	description="Archivo completo de articulos sobre Astro, contenido y flujos editoriales modernos."
>
	<section class="page-hero">
		<span class="eyebrow">Archivo editorial</span>
		<h1>Todos los articulos del blog</h1>
		<p>
			Archivo completo de la publicacion: entradas, temas y una reticula pensada para que el
			contenido respire como una revista digital, no como un listado plano.
		</p>
	</section>

	<section class="section">
		<div class="section-heading">
			<div>
				<p class="section-label">Indice tematico</p>
				<h2>Etiquetas activas</h2>
				<p>Una taxonomia ligera ayuda a navegar sin convertir el proyecto en una base de datos opaca.</p>
			</div>
		</div>

		<ul class="topic-list">
			{tags.map((tag) => <li>{tag}</li>)}
		</ul>
	</section>

	<section class="section">
		<div class="post-grid">
			{posts.map((post) => <PostCard post={post} />)}
		</div>
	</section>
</BaseLayout>
