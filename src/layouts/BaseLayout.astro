---
import '../styles/global.css';
import { siteConfig } from '../config/site';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { withBase } from '../utils/links';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = siteConfig.title,
	description = siteConfig.description,
} = Astro.props;

const pageTitle = title === siteConfig.title ? title : `${title} | ${siteConfig.title}`;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : undefined;
const socialImage = Astro.site ? new URL(withBase('/favicon.svg'), Astro.site).toString() : undefined;
---

<!doctype html>
<html lang="es">
	<head>
		<!--
			BLOQUE: Metadatos base del sitio
			- Este layout envuelve todas las paginas publicas.
			- Aqui se centralizan SEO, Open Graph, favicon y fuentes.
			
			Por que es importante:
			- Si esta informacion se repite pagina por pagina, el mantenimiento se complica enseguida.
			- En Astro, un layout es el mejor sitio para compartir esta capa comun.
		-->
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#8d2f23" />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		{canonical && <meta property="og:url" content={canonical} />}
		{socialImage && <meta property="og:image" content={socialImage} />}
		<meta name="twitter:card" content="summary_large_image" />
		{canonical && <link rel="canonical" href={canonical} />}
		<link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
		<link rel="icon" href={withBase('/favicon.ico')} />
		<link rel="alternate" type="application/rss+xml" title="RSS" href={withBase('/rss.xml')} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Fraunces:wght@600;700&family=IBM+Plex+Mono:wght@400;500&family=Manrope:wght@400;500;700;800&display=swap"
			rel="stylesheet"
		/>
		<title>{pageTitle}</title>
	</head>
	<body>
		<div class="site-shell">
			<SiteHeader />
			<main class="main-content">
				<div class="container">
					<slot />
				</div>
			</main>
			<SiteFooter />
		</div>
		<script is:inline>
			(() => {
				/**
				 * BLOQUE: Header que se esconde al bajar
				 * - Mantiene visible la cabecera al cargar y al subir.
				 * - La oculta al hacer scroll descendente para dar mas espacio al contenido.
				 *
				 * Contexto practico:
				 * - En una web editorial, el header suele ser alto por branding y navegacion.
				 * - Esta tecnica evita que robe demasiada altura cuando el lector ya esta leyendo.
				 *
				 * Ajuste de estabilidad:
				 * - Ignoramos microcambios de scroll para que touchpads y ruedas sensibles
				 *   no hagan que la cabecera parpadee o parezca "nerviosa".
				 */
				const header = document.querySelector('.site-header');

				if (!header) return;

				let lastScrollY = window.scrollY;
				let ticking = false;
				const hideAfter = 96;
				const minDelta = 12;

				const syncHeaderState = () => {
					const currentScrollY = window.scrollY;
					const nearTop = currentScrollY <= hideAfter;
					const delta = currentScrollY - lastScrollY;

					if (nearTop) {
						header.classList.remove('site-header--hidden');
						lastScrollY = currentScrollY;
						ticking = false;
						return;
					}

					if (Math.abs(delta) < minDelta) {
						ticking = false;
						return;
					}

					header.classList.toggle('site-header--hidden', delta > 0);
					lastScrollY = currentScrollY;
					ticking = false;
				};

				syncHeaderState();
				window.addEventListener(
					'scroll',
					() => {
						if (ticking) return;
						ticking = true;
						window.requestAnimationFrame(syncHeaderState);
					},
					{ passive: true }
				);
			})();
		</script>
	</body>
</html>
